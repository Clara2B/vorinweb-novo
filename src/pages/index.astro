    <div class="blk-hdr">
      <span class="blk-eyebrow"><svg class="ico" style="width:14px;height:14px"><use href="#ic-award"></use></svg> Projetos reais</span>
    </div>
    <div class="real-grid">

      <div class="real-card">
        <div class="real-top">
          <span class="tag-real">Projeto real</span>
          <span class="real-seg">E-commerce · Suplementos</span>
        </div>
