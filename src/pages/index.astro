---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout path="/">

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-grid-lines"></div>
  <div class="hero-inner">
    <div>
      <div class="hero-tag">
        <span class="hero-tag-dot"></span>
        Aberto para novos projetos
      </div>
      <h1>
        Do site ao sistema,<br>
        sob <em>um só time</em><br>
        que não some depois
      </h1>
      <p class="hero-sub">
        A VorinWeb projeta e constrói sites, lojas virtuais, sistemas sob medida e bots de automação para negócios que querem <strong>mais clientes e menos trabalho manual</strong> — com suporte de verdade antes, durante e depois da entrega.
      </p>
      <div class="hero-btns">
        <a href="https://wa.me/5511934900204" target="_blank" class="btn-wpp"><svg class="ico"><use href="#ic-message"></use></svg> Quero começar agora</a>
        <a href="#solucoes" class="btn-o">Ver o que construímos</a>
      </div>
      <div class="hero-proof">
        <div class="hp">
          <span class="hp-val">15+</span>
          <span class="hp-label">projetos entregues</span>
        </div>
        <div class="hp-sep"></div>
        <div class="hp">
          <span class="hp-val">10 dias</span>
          <span class="hp-label">prazo padrão de entrega</span>
        </div>
        <div class="hp-sep"></div>
        <div class="hp">
          <span class="hp-val">&lt; 1h</span>
          <span class="hp-label">compromisso de resposta</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-glow"></div>
      <div class="hero-mockup">
        <div class="mk-bar">
          <div class="mk-dot"></div><div class="mk-dot"></div><div class="mk-dot"></div>
          <div class="mk-url">seunegocio.com.br</div>
        </div>
        <div class="mk-body">
          <div class="mk-strip">
            <div class="mk-t1"></div><div class="mk-t2"></div><div class="mk-t3"></div>
          </div>
          <div class="mk-cards">
            <div class="mk-card"><div class="mk-ci"></div><div class="mk-l"></div><div class="mk-ls"></div></div>
            <div class="mk-card"><div class="mk-ci"></div><div class="mk-l"></div><div class="mk-ls"></div></div>
            <div class="mk-card"><div class="mk-ci"></div><div class="mk-l"></div><div class="mk-ls"></div></div>
          </div>
        </div>
      </div>
      <div class="hero-badge-float hbf-left">
        <div class="hbf-label">Atendimento</div>
        <div class="hbf-val" style="color:#22c55e;font-size:.85rem;"><svg class="ico" style="width:14px;height:14px"><use href="#ic-check-circle"></use></svg> 100% personalizado</div>
        <div class="hbf-sub">nada de template genérico</div>
      </div>
      <div class="hero-badge-float hbf-right">
        <div class="hbf-label"><span class="online-dot"></span>Suporte ativo</div>
        <div class="hbf-val" style="font-size:.9rem;">Online</div>
        <div class="hbf-sub">resposta em &lt; 1h</div>
      </div>
    </div>
  </div>
</section>

<!-- SEGMENTOS -->
<section id="segmentos">
  <div class="seg-inner">
    <div class="seg-label">Atendemos negócios como</div>
    <div class="seg-list">
      <div class="seg-chip"><svg class="ico"><use href="#ic-bowl"></use></svg> Restaurantes e bares</div>
      <div class="seg-chip"><svg class="ico"><use href="#ic-heart"></use></svg> Clínicas e consultórios</div>
      <div class="seg-chip"><svg class="ico"><use href="#ic-bag"></use></svg> Lojas online</div>
      <div class="seg-chip"><svg class="ico"><use href="#ic-scissors"></use></svg> Salões e estéticas</div>
      <div class="seg-chip"><svg class="ico"><use href="#ic-briefcase"></use></svg> Escritórios e autônomos</div>
      <div class="seg-chip"><svg class="ico"><use href="#ic-users"></use></svg> Portfólios pessoais</div>
    </div>
  </div>
</section>

<div class="section-line"></div>

<!-- COMO FUNCIONA -->
<section id="como">
  <div class="si">
    <div class="s-label">Processo</div>
    <h2 class="s-title">Do zero ao ar em 3 passos</h2>
    <p class="s-sub">Sem reuniões intermináveis, sem surpresas no caminho. Você explica o que precisa e a gente faz acontecer.</p>
    <div class="steps-g">
      <div class="step-card">
        <div class="step-num">01</div>
        <div class="step-t">Você conta o projeto</div>
        <div class="step-d">Uma conversa rápida pelo WhatsApp ou preenchendo o formulário. A gente entende o seu negócio, o que precisa e o prazo que faz sentido pra você.</div>
        <div class="step-detail"><svg class="ico" style="width:13px;height:13px"><use href="#ic-clock"></use></svg> 15 min de conversa</div>
      </div>
      <div class="step-card">
        <div class="step-num">02</div>
        <div class="step-t">A gente desenvolve</div>
        <div class="step-d">Prazo combinado e cumprido. Você acompanha o andamento e vê o rascunho antes de finalizar. Nada vai pro ar sem a sua aprovação.</div>
        <div class="step-detail"><svg class="ico" style="width:13px;height:13px"><use href="#ic-calendar"></use></svg> Até 10 dias úteis</div>
      </div>
      <div class="step-card">
        <div class="step-num">03</div>
        <div class="step-t">No ar e gerando cliente</div>
        <div class="step-d">Site publicado, domínio configurado, pronto pra receber visitas. Se quiser continuar evoluindo, temos planos mensais sem fidelidade.</div>
        <div class="step-detail"><svg class="ico" style="width:13px;height:13px"><use href="#ic-rocket"></use></svg> Suporte pós-entrega</div>
      </div>
    </div>
  </div>
</section>

<div class="section-line"></div>

<!-- SOLUÇÕES -->
