---
const navLinks = [
  { href: "#como", label: "Como funciona" },
  { href: "#solucoes", label: "Soluções" },
  { href: "#planos", label: "Planos" },
  { href: "#faq", label: "Dúvidas" },
];
---
<nav>
  <div class="nav-left">
    <a href="/" class="nav-logo">Vorin<span>Web</span></a>
    <ul class="nav-links">
      {navLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </div>
  <div class="nav-right">
    <button class="tog" id="themeToggle" aria-label="Alternar tema">
      <span class="tog-icon icon-moon"><svg class="ico" style="width:12px;height:12px"><use href="#ic-moon"></use></svg></span>
      <span class="tog-icon icon-sun"><svg class="ico" style="width:12px;height:12px"><use href="#ic-sun"></use></svg></span>
    </button>
    <a href="https://wa.me/5511934900204" target="_blank" class="nav-cta">
      <svg class="ico"><use href="#ic-message"></use></svg> Falar no WhatsApp
    </a>
    <button class="nav-burger" id="navBurger" aria-label="Abrir menu" aria-expanded="false">
      <svg class="ico burger-open"><use href="#ic-menu"></use></svg>
      <svg class="ico burger-close"><use href="#ic-close"></use></svg>
    </button>
  </div>
</nav>

<div class="mobile-nav" id="mobileNav">
  <ul class="mobile-nav-links">
    {navLinks.map((link) => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
    <li><a href="#contato">Contato</a></li>
  </ul>
  <a href="https://wa.me/5511934900204" target="_blank" class="nav-cta mobile-nav-cta">
    <svg class="ico"><use href="#ic-message"></use></svg> Falar no WhatsApp
  </a>
</div>
